# IA Hoteles Agent - Environment Variables Template
# v4.0.0 - Sistema de Confianza

# === API Keys para Validación Externa (REQUERIDAS v4.0) ===
# PageSpeed Insights API - Para validación real de Core Web Vitals
# Obtener en: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# === API Keys para Generación de Contenido ===
# DeepSeek API - Para generación de contenido (Opcional)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic API - Alternativa para generación (Opcional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === API Keys para Visibilidad IA ===
# OpenAI API - Para testing en ChatGPT (Opcional)
OPENAI_API_KEY=your_o...here

# Perplexity API - Para testing de visibilidad (Opcional)
PERPLEXITY_API_KEY=your_p...here

# Google Maps API - Para Places API y fotos (Opcional)
GOOGLE_MAPS_API_KEY=your_g...here

# === Google Analytics 4 (Opcional - Método #5 KB) ===
# GA4 Property ID - Obtener en GA4 Admin > Property Settings
# Ejemplo: "123456789"
GA4_PROPERTY_ID=your_ga4_property_id_here

# Ruta al archivo JSON de Service Account de Google Cloud
# Crear en: Google Cloud Console > IAM > Service Accounts
# Luego: GA4 Admin > User Management > Agregar service account con rol "Viewer"
GA4_CREDENTIALS_PATH=/path/to/your/service-account-credentials.json

# === Configuración de WordPress ===
# Solo necesario para despliegue automático
WP_BASE_URL=https://your-hotel.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password

# === Configuración de Base de Datos (Opcional) ===
# Para almacenamiento persistente de análisis
DATABASE_URL=sqlite:///data/iah_database.db
